# Hermes portable config — secrets excluded
# See README.md for how to add local secrets per machine.

# Ignore everything by default
*

# Then un-ignore the portable files/folders we want to sync
!.gitignore
!README.md
!SOUL.md
!config.yaml
!setup-*.sh
!cron/
!cron/*/
!cron/*/*/
!cron/*/*/*/
!cron/*.json
!cron/**/*.json
!cron/*.md
!cron/**/*.md
!cron/*.sh
!cron/**/*.sh
!cron/*.py
!cron/**/*.py
!cron/*.yaml
!cron/**/*.yaml
!cron/*.yml
!cron/**/*.yml
!cron/*.lock
!cron/**/*.lock
!skills/
!skills/*/
!skills/*/*/
!skills/*/*/*/
!skills/*/*/*/*/
!skills/*.md
!skills/**/*.md
!skills/*.txt
!skills/**/*.txt
!skills/*.json
!skills/**/*.json
!skills/*.yaml
!skills/**/*.yaml
!skills/*.yml
!skills/**/*.yml
!skills/*.py
!skills/**/*.py
!skills/*.sh
!skills/**/*.sh
!skills/*.js
!skills/**/*.js
!skills/*.ts
!skills/**/*.ts
!skills/*.css
!skills/**/*.css
!skills/*.html
!skills/**/*.html
!skills/*.xml
!skills/**/*.xml
!skills/*.xsd
!skills/**/*.xsd

# Ignore runtime state / logs inside cron and skills (must come AFTER un-ignores)
cron/.jobs.lock
cron/.tick.lock
cron/jobs.json
cron/output/**
cron/ticker_heartbeat
cron/ticker_last_success
skills/.bundled_manifest
skills/.curator_state
skills/.usage.json
skills/.usage.json.lock

# Any local secrets that may have been copied accidentally
credentials/
*.env
.env
secrets/
auth.json
*.pem
*.key
